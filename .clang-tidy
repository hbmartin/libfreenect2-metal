# Static-analysis checks for libfreenect2 (advisory CI job, changed files only).
# Conservative, high-signal set; naming/readability churn is intentionally off.
Checks: >
  -*,
  bugprone-*,
  clang-analyzer-*,
  performance-*,
  misc-definitions-in-headers,
  -bugprone-easily-swappable-parameters,
  -bugprone-narrowing-conversions,
  -bugprone-reserved-identifier,
  -clang-analyzer-optin.performance.Padding
WarningsAsErrors: ''
HeaderFilterRegex: '.*/libfreenect2/.*'
FormatStyle: file
